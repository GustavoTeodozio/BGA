# Copie este arquivo, preencha e cole nas variáveis de ambiente do EasyPanel

# ─── POSTGRES ───────────────────────────────────────────
POSTGRES_USER=bga
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=bga

# ─── BACKEND ────────────────────────────────────────────
NODE_ENV=production
PORT=3333
APP_URL=https://SEU_DOMINIO

# Monte a DATABASE_URL com as mesmas credenciais do Postgres acima
# Formato: postgresql://USUARIO:SENHA@NOME_SERVICO_POSTGRES:5432/BANCO
# No EasyPanel o hostname do postgres é o nome do serviço (ex: bga_postgres)
DATABASE_URL=postgresql://bga:TROQUE_POR_UMA_SENHA_FORTE@bga_postgres:5432/bga?sslmode=disable

REDIS_URL=redis://bga_redis:6379/0

# Gere com: openssl rand -base64 32
JWT_SECRET=GERE_CHAVE_FORTE_AQUI
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=GERE_OUTRA_CHAVE_FORTE_AQUI
REFRESH_TOKEN_EXPIRES_IN=7d

STORAGE_DRIVER=local
