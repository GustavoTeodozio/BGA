# Variáveis de ambiente para o serviço BACKEND no EasyPanel

NODE_ENV=production
PORT=3333
APP_URL=https://app.bgastands.com.br

DATABASE_URL=postgres://postgres:postgres@bga_postgres:5432/bga?sslmode=disable
REDIS_URL=redis://default:redis@bga_redis:6379

# Gere com: openssl rand -base64 32
JWT_SECRET=GERE_CHAVE_FORTE_AQUI
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=GERE_OUTRA_CHAVE_FORTE_AQUI
REFRESH_TOKEN_EXPIRES_IN=7d

STORAGE_DRIVER=local
